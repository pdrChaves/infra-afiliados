# --- Postgres ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Login do painel do n8n (http://localhost:5678) ---
N8N_USER=
N8N_PASSWORD=

# --- Chave de criptografia do n8n ---
# Gere uma aleatoria. No PowerShell:  [guid]::NewGuid().ToString()
# Ou no Git Bash/WSL:  openssl rand -hex 24
# Depois de definida, NAO mude (perde acesso as credenciais salvas)
N8N_ENCRYPTION_KEY=
